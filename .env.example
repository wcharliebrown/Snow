# Snow Framework Configuration
# Database Settings
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=snow
DB_USER=your_db_user
DB_PASS=your_db_password

# Site Settings
SITE_NAME=Snow Framework
SITE_URL=http://localhost:8080
ADMIN_EMAIL=admin@example.com

# Security Settings
SESSION_TIMEOUT=3600
PASSWORD_MIN_LENGTH=8
ENCRYPTION_KEY=change_me_to_a_32_char_secret_key

# Logging Settings
LOG_LEVEL=2
LOG_TRAFFIC=1
LOG_ERRORS=1
LOG_EMAIL=1

# Email Settings
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# Development/Production
DEV_MODE=1
DEBUG=1